<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface_container_low"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp"
    android:foreground="@drawable/ripple_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTokenNum"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_token_circle"
            android:gravity="center"
            android:text="#1"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPatientName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient Name"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvPatientInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Age: 40 | Priority: Normal"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:id="@+id/layoutQueueActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical"
                android:baselineAligned="false"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQueuePrescription"
                    style="@style/SmartQ.Button.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Prescription"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQueueNoShow"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                        android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:text="No-show"
                    android:textColor="@color/error"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                        android:gravity="center"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_status_pill"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
