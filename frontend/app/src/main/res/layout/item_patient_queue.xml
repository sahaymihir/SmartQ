<?xml version="1.0" encoding="utf-8"?>
<!-- Save as res/layout/item_patient_queue.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Position badge -->
        <TextView
            android:id="@+id/tvItemPosition"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/circle_primary"/>

        <!-- Patient info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">

                <!-- Priority badge -->
                <TextView
                    android:id="@+id/tvItemPriority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Normal"
                    android:textSize="10sp"
                    android:textColor="@color/white"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:background="@drawable/badge_normal"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvItemEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="~8 min"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </LinearLayout>

        <!-- No-show button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnItemNoShow"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No-show"
            android:textColor="@color/error"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>