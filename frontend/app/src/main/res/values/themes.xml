<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- SmartQ Dark Clinical Theme                          -->
    <!-- ═══════════════════════════════════════════════════ -->

    <style name="Theme.SmartQ" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/on_tertiary_container</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>

        <!-- Surface / Background -->
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:colorBackground">@color/surface</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:forceDarkAllowed">false</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/surface_container_lowest</item>
        <item name="android:navigationBarDividerColor">@color/surface_container_lowest</item>

        <!-- Activity Transitions -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowContentTransitions">true</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/on_surface_variant</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Splash Theme — Deep gradient effect -->
    <style name="Theme.SmartQ.Splash" parent="Theme.SmartQ">
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Android 12+ Core Splash Screen Theme for Seamless Launch -->
    <style name="Theme.SmartQ.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/surface</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartQ.Splash</item>
    </style>

    <!-- ── Card Styles ─────────────────────────────────── -->

    <!-- Dark Glass Card -->
    <style name="SmartQ.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/surface_container_low</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Elevated Glass Card -->
    <style name="SmartQ.Card.Glass" parent="SmartQ.Card">
        <item name="cardBackgroundColor">@color/glass_bg</item>
        <item name="cardElevation">8dp</item>
    </style>

    <!-- Primary-tinted Card -->
    <style name="SmartQ.Card.Primary" parent="SmartQ.Card">
        <item name="cardBackgroundColor">@color/primary_container</item>
        <item name="strokeColor">@color/primary_dark</item>
    </style>

    <!-- ── Button Styles ───────────────────────────────── -->

    <!-- Primary CTA — Gradient will be applied via drawable background -->
    <style name="SmartQ.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/on_primary</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Gradient CTA Button -->
    <style name="SmartQ.Button.Gradient" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_cta_gradient</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Outlined Button -->
    <style name="SmartQ.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="SmartQ.Button.Secondary" parent="SmartQ.Button.Outlined">
        <item name="android:textColor">@color/on_surface</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="SmartQ.Button.Back" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Text Button -->
    <style name="SmartQ.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Stable choice chip style for role filters -->
    <style name="SmartQ.Chip.Filter" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_filter_background</item>
        <item name="chipStrokeColor">@color/chip_filter_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/chip_filter_text</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipMinHeight">36dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.MaterialComponents.SmallComponent</item>
    </style>

    <!-- ── Text Input ──────────────────────────────────── -->

    <!-- Clinical Precision Input — Bottom line style -->
    <style name="SmartQ.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">0dp</item>
        <item name="boxCornerRadiusTopEnd">0dp</item>
        <item name="boxCornerRadiusBottomStart">0dp</item>
        <item name="boxCornerRadiusBottomEnd">0dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/transparent</item>
        <item name="boxStrokeWidth">2dp</item>
    </style>

    <!-- Outlined Box Input — For form fields -->
    <style name="SmartQ.TextInput.Outlined" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/outline_variant</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/surface_container_low</item>
    </style>

</resources>
