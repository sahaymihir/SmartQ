<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDialogTitle"
            style="@style/SmartQ.Text.ScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit nurse vitals"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tvDialogSubtitle"
            style="@style/SmartQ.Text.ScreenSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Patient · Token #" />

        <TextView
            style="@style/SmartQ.Text.SectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Vitals and notes" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SmartQ.TextInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Temperature (C)"
            app:helperText="Typical adult range: 35.0 - 42.0"
            app:placeholderText="e.g. 37.0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTemperature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SmartQ.TextInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="SpO2"
            app:helperText="Oxygen saturation percent"
            app:placeholderText="e.g. 98">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSpo2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SmartQ.TextInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Respiratory rate"
            app:helperText="Breaths per minute"
            app:placeholderText="e.g. 18">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRespiratoryRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SmartQ.TextInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Heart rate"
            app:helperText="Beats per minute"
            app:placeholderText="e.g. 80">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHeartRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SmartQ.TextInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Systolic BP"
            app:helperText="Upper blood pressure value (mmHg)"
            app:placeholderText="e.g. 120">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSystolicBp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SmartQ.TextInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Diastolic BP"
            app:helperText="Lower blood pressure value (mmHg)"
            app:placeholderText="e.g. 80">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDiastolicBp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SmartQ.TextInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Current mental status"
            app:endIconMode="dropdown_menu"
            app:helperText="Used to derive GCS automatically">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/dropdownMentalStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SmartQ.TextInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Pain score"
            app:helperText="Pain intensity: 0 - 10"
            app:placeholderText="e.g. 0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPainScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/SmartQ.TextInput.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Triage note"
            app:helperText="Short nursing observation (optional)"
            app:placeholderText="e.g. Alert, speaking full sentences">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTriageNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogCancel"
                style="@style/SmartQ.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogSubmit"
                style="@style/SmartQ.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Submit vitals" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
