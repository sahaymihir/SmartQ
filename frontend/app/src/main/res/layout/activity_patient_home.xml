<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Top Bar ─────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good morning,"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tvPatientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient Name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- ── NOT IN QUEUE STATE ────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutNotInQueue"
            android:animateLayoutChanges="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Illustration card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/SmartQ.Card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Queue"
                        android:textSize="56sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ready to join?"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skip the waiting room.\nJoin the queue digitally."
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Visit type selection card ──────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/SmartQ.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/visit_type_label"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="10dp"/>

                    <RadioGroup
                        android:id="@+id/rgVisitType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbVisitNew"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/visit_type_new"
                            android:checked="true"
                            android:textColor="@color/on_surface"
                            android:buttonTint="@color/primary"/>

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbVisitFollowUp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/visit_type_follow_up"
                            android:textColor="@color/on_surface"
                            android:buttonTint="@color/primary"/>
                    </RadioGroup>

                    <!-- Follow-up info note (shown when follow-up selected) -->
                    <LinearLayout
                        android:id="@+id/layoutFollowUpNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_frosted_card"
                        android:padding="10dp"
                        android:layout_marginTop="10dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/visit_type_follow_up"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"/>

                        <TextView
                            android:id="@+id/tvFollowUpNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/follow_up_note"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnChooseFollowUp"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/follow_up_choose_visit"
                            android:textColor="@color/primary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Symptoms input card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/SmartQ.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ML"
                            android:textSize="18sp"
                            android:layout_marginEnd="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Describe your symptoms"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Predictions suggest the best doctor"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"/>
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/SmartQ.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. chest pain, fever, joint ache...">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSymptoms"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="2"
                            android:maxLines="4"
                            android:inputType="textMultiLine|textCapSentences"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFindDoctor"
                        style="@style/SmartQ.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Find Best Doctor"
                        android:layout_marginTop="10dp"/>

                    <!-- Prediction result (hidden until prediction runs) -->
                    <LinearLayout
                        android:id="@+id/layoutAiResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_frosted_card"
                        android:padding="10dp"
                        android:layout_marginTop="10dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ML"
                            android:textSize="16sp"
                            android:layout_marginEnd="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvAiPickTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Prediction"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>

                            <TextView
                                android:id="@+id/tvAiPickMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Clinical fit"
                                android:textSize="10sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp"
                                android:maxLines="2"/>

                            <TextView
                                android:id="@+id/tvAiPickReasoning"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp"
                                android:maxLines="4"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Doctor list card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/SmartQ.Card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Select Doctor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:id="@+id/tvSelectedDoctor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None selected"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Search field -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/SmartQ.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Search by name or specialty"
                        android:layout_marginBottom="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDoctorSearch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textSize="14sp"
                            android:imeOptions="actionSearch"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Loading indicator -->
                    <TextView
                        android:id="@+id/tvDoctorListLoading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading doctors..."
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="visible"/>

                    <!-- Doctor list (populated dynamically) -->
                    <LinearLayout
                        android:id="@+id/layoutDoctorList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/SmartQ.Card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/history_title"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvHistoryEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/history_empty"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"/>

                    <LinearLayout
                        android:id="@+id/layoutHistoryList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Join button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinQueue"
                style="@style/SmartQ.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Join Queue"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

        <!-- ── IN QUEUE STATE ────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutInQueue"
            android:animateLayoutChanges="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- ── Test recommendations card (shown when wait is high) ──── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTestRecs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_container_low"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧪"
                            android:textSize="18sp"
                            android:layout_marginEnd="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/test_recs_title"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/test_recs_subtitle"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp"
                                android:maxLines="3"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Test list populated dynamically -->
                    <LinearLayout
                        android:id="@+id/layoutTestRecsList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="6dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDismissTestRecs"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="@string/test_recs_dismiss"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Token + Position card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/primary"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Token number + doctor -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Your Token"
                                android:textSize="12sp"
                                android:textColor="#AAFFFFFF"/>

                            <TextView
                                android:id="@+id/tvTokenNumber"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="#42"
                                android:textSize="36sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"/>

                            <TextView
                                android:id="@+id/tvDoctorName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dr. Nisha Shetty"
                                android:textSize="13sp"
                                android:textColor="#CCFFFFFF"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <!-- Position circle -->
                        <LinearLayout
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/circle_white_alpha">

                            <TextView
                                android:id="@+id/tvPosition"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="in line"
                                android:textSize="10sp"
                                android:textColor="#CCFFFFFF"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"/>

                    <!-- ETA row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvETA"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="~24 min"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Estimated Wait"
                                android:textSize="11sp"
                                android:textColor="#AAFFFFFF"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#33FFFFFF"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvQueueStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Waiting"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Status"
                                android:textSize="11sp"
                                android:textColor="#AAFFFFFF"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Check-in card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCheckin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/SmartQ.Card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check-in"
                        android:textSize="24sp"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCheckinTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not checked in yet"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:id="@+id/tvCheckinSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap when you arrive at the hospital"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckIn"
                        style="@style/SmartQ.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check In"
                        android:textSize="13sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Snooze card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSnooze"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/SmartQ.Card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delay"
                        android:textSize="24sp"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Running late?"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:id="@+id/tvSnoozeCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Push back 2 spots (0/2 used)"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSnooze"
                        style="@style/SmartQ.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Snooze"
                        android:textSize="13sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Leave queue -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeaveQueue"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Leave Queue"
                android:textColor="@color/error"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

        <!-- ── CALLED STATE ───────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCalled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
                app:cardBackgroundColor="@color/primary_container"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alert"
                    android:textSize="48sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="It's Your Turn!"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginTop="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Please proceed to the consultation room now."
                    android:textSize="14sp"
                    android:textColor="#CCDAE2FD"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_cta_gradient"
                    android:textColor="@color/primary_container"
                    android:text="Done — Leave Queue"
                    android:layout_marginTop="24dp"
                    app:backgroundTint="@null"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
