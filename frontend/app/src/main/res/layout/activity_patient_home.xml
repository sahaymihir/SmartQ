<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Ambient Glow -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="end"
        android:layout_marginEnd="-100dp"
        android:layout_marginTop="-80dp"
        android:background="@drawable/bg_ambient_glow"
        android:alpha="0.3"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ═══ TOP BAR ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <!-- SmartQ branding -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_clinical_notes"
                        android:contentDescription="SmartQ"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.03"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Logout"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textAllCaps="false"/>
            </LinearLayout>

            <!-- ═══ GREETING ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good morning,"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_variant"/>

                <TextView
                    android:id="@+id/tvPatientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient Name"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02"/>
            </LinearLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!-- NOT IN QUEUE STATE                          -->
            <!-- ═══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutNotInQueue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Hero Card with Lottie -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_gradient_border_card"
                    android:padding="32dp"
                    android:layout_marginBottom="16dp">

                    <com.airbnb.lottie.LottieAnimationView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:lottie_rawRes="@raw/lottie_medical_pulse"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        app:lottie_speed="0.7"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ready to join?"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skip the waiting room.\nJoin the queue digitally."
                        android:textSize="14sp"
                        android:textColor="@color/on_surface_variant"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.5"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- Doctor Selector -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_container_low"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SELECT SPECIALIST"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="12dp"/>

                        <RadioGroup
                            android:id="@+id/rgDoctor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/rbDoctor1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Dr. Nisha Shetty — General OPD"
                                android:checked="true"
                                android:textColor="@color/on_surface"
                                android:buttonTint="@color/primary"
                                android:padding="8dp"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/rbDoctor2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Dr. Pawan Kumar — Orthopaedics"
                                android:textColor="@color/on_surface"
                                android:buttonTint="@color/primary"
                                android:padding="8dp"/>

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/rbDoctor3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Dr. Meena Rao — Cardiology"
                                android:textColor="@color/on_surface"
                                android:buttonTint="@color/primary"
                                android:padding="8dp"/>
                        </RadioGroup>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- AI Triage Input -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_container_low"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🧠"
                                android:textSize="20sp"
                                android:layout_marginEnd="8dp"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="AI TRIAGE"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary"
                                    android:letterSpacing="0.15"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Describe symptoms for smart prioritization"
                                    android:textSize="11sp"
                                    android:textColor="@color/on_surface_variant"/>
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. severe headache, fever 102°F, nausea"
                            style="@style/SmartQ.TextInput.Outlined">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSymptoms"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textMultiLine"
                                android:minLines="2"
                                android:maxLines="4"
                                android:textSize="14sp"
                                android:textColor="@color/on_surface"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Join Queue CTA — Pill -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnJoinQueue"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_cta_pill"
                    android:text="Join Queue  →"
                    android:textColor="@color/surface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@null"
                    app:cornerRadius="28dp"
                    app:elevation="8dp"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!-- IN QUEUE STATE                              -->
            <!-- ═══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutInQueue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Live Session Badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_status_pill"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@color/status_active"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE SESSION ACTIVE"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_light"
                        android:letterSpacing="0.15"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You're in line."
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.03"
                    android:layout_marginBottom="16dp"/>

                <!-- Token + Position Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_container_low"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <!-- Doctor label + Token -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="YOUR TOKEN"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_secondary"
                                    android:letterSpacing="0.15"/>

                                <TextView
                                    android:id="@+id/tvTokenNumber"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="#42"
                                    android:textSize="40sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary"
                                    android:fontFamily="sans-serif-black"/>

                                <TextView
                                    android:id="@+id/tvDoctorName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Dr. Nisha Shetty"
                                    android:textSize="13sp"
                                    android:textColor="@color/on_surface_variant"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <!-- Position Circle with Neon Ring -->
                            <FrameLayout
                                android:layout_width="100dp"
                                android:layout_height="100dp">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_neon_ring"/>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:gravity="center">

                                    <TextView
                                        android:id="@+id/tvPosition"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="4"
                                        android:textSize="36sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/primary"
                                        android:fontFamily="sans-serif-black"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Position"
                                        android:textSize="9sp"
                                        android:textColor="@color/on_surface_variant"
                                        android:textAllCaps="true"
                                        android:letterSpacing="0.1"/>
                                </LinearLayout>
                            </FrameLayout>
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/outline_variant"
                            android:alpha="0.4"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="20dp"/>

                        <!-- ETA + Status -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/tvETA"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="~24 min"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/on_surface"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ESTIMATED WAIT"
                                    android:textSize="9sp"
                                    android:textColor="@color/text_secondary"
                                    android:textAllCaps="true"
                                    android:letterSpacing="0.1"/>
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="40dp"
                                android:background="@color/outline_variant"
                                android:alpha="0.4"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/tvQueueStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Waiting"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/on_surface"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="STATUS"
                                    android:textSize="9sp"
                                    android:textColor="@color/text_secondary"
                                    android:textAllCaps="true"
                                    android:letterSpacing="0.1"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Check-in Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCheckin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_container_low"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍"
                            android:textSize="24sp"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvCheckinTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Not checked in yet"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"/>

                            <TextView
                                android:id="@+id/tvCheckinSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap when you arrive at the hospital"
                                android:textSize="12sp"
                                android:textColor="@color/on_surface_variant"/>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheckIn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_cta_gradient"
                            android:text="Check In"
                            android:textColor="@color/primary_container"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            app:backgroundTint="@null"
                            app:cornerRadius="10dp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Snooze Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSnooze"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_container_low"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏰"
                            android:textSize="24sp"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Running late?"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"/>

                            <TextView
                                android:id="@+id/tvSnoozeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Push back 2 spots (0/2 used)"
                                android:textSize="12sp"
                                android:textColor="@color/on_surface_variant"/>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSnooze"
                            style="@style/SmartQ.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Snooze"
                            android:textSize="12sp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Leave Queue -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLeaveQueue"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Leave Queue"
                    android:textColor="@color/error"
                    android:textAllCaps="false"
                    android:layout_marginBottom="8dp"/>
            </LinearLayout>

            <!-- ═══════════════════════════════════════════ -->
            <!-- CALLED STATE                                -->
            <!-- ═══════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCalled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/primary_dark"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:background="@drawable/bg_cta_gradient">

                    <com.airbnb.lottie.LottieAnimationView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        app:lottie_rawRes="@raw/lottie_success"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="false"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="It's Your Turn!"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/surface"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Please proceed to the consultation room now."
                        android:textSize="14sp"
                        android:textColor="#CC001A29"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginTop="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDone"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:backgroundTint="@color/surface"
                        android:textColor="@color/primary"
                        android:text="Done — Leave Queue"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:layout_marginTop="28dp"
                        app:cornerRadius="28dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</FrameLayout>