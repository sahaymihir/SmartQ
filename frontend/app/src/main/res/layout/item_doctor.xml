<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDoctorItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp"
    android:layout_marginBottom="8dp"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Specialty initial circle -->
        <TextView
            android:id="@+id/tvDoctorInitial"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/circle_primary"/>

        <!-- Name + Specialty -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvDoctorItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvDoctorItemSpecialty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Specialty"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- AI Recommended badge (hidden by default) -->
        <TextView
            android:id="@+id/tvAiPick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 AI Pick"
            android:textSize="10sp"
            android:textColor="@color/white"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/badge_normal"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <!-- Selected checkmark (hidden by default) -->
        <TextView
            android:id="@+id/tvDoctorSelectedMark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="20sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:visibility="gone"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
