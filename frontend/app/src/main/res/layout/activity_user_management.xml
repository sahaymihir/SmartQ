<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- ── Top Bar ──────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/surface_container_low">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/SmartQ.Button.Back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="User Management"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:paddingStart="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddUser"
            style="@style/SmartQ.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add User"
            android:textSize="13sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:cornerRadius="12dp"/>
    </LinearLayout>

    <!-- ── Role Filter Chips ────────────────────────────────── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                style="@style/SmartQ.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:checked="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDoctors"
                style="@style/SmartQ.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Doctors"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNurses"
                style="@style/SmartQ.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nurses"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPatients"
                style="@style/SmartQ.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patients"/>

            <!-- Hidden for non-superusers — visibility set in code -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAdmins"
                style="@style/SmartQ.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admins"/>

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- ── Progress Bar ─────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"/>

    <!-- ── User List ─────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/layoutUserList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <!-- ── Empty State ───────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No users found."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

</LinearLayout>
